{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Feature Spec Schema",
  "description": "JSON Schema для валидации Feature Spec документов",
  "type": "object",
  "required": [
    "artifactId",
    "traceability",
    "purpose",
    "userStories",
    "screens",
    "useCases",
    "domainModel",
    "dataSources",
    "cachePolicy",
    "degradationPolicy",
    "analytics",
    "testRequirements"
  ],
  "properties": {
    "artifactId": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "format": {
          "type": "string",
          "pattern": "^FEATURE-\\d+$",
          "description": "Формат идентификатора: FEATURE-<number>"
        },
        "id": {
          "type": "string",
          "pattern": "^FEATURE-\\d+$",
          "description": "Уникальный идентификатор фичи"
        }
      }
    },
    "traceability": {
      "type": "object",
      "required": ["relatedScreens"],
      "properties": {
        "relatedFeatures": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^FEATURE-\\d+$"
          },
          "description": "Список связанных фич"
        },
        "relatedScreens": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^SCREEN-\\d+$|^SCREEN-[A-Z0-9-]+$"
          },
          "description": "Список всех экранов фичи (обязательно)"
        },
        "relatedUseCases": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Список use cases из раздела 4"
        },
        "relatedApiContracts": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Список операций API из contracts/api.md"
        }
      }
    },
    "purpose": {
      "type": "object",
      "required": ["goal", "outOfScope"],
      "properties": {
        "goal": {
          "type": "string",
          "description": "Цель фичи"
        },
        "outOfScope": {
          "type": "string",
          "description": "Что вне границ фичи"
        }
      }
    },
    "userStories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "Пользовательские сценарии"
    },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "sections": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "description": "Экраны и состав UI"
    },
    "useCases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "goal", "input", "output"],
        "properties": {
          "name": {
            "type": "string"
          },
          "goal": {
            "type": "string"
          },
          "input": {
            "type": "string"
          },
          "output": {
            "type": "string"
          }
        }
      },
      "description": "Use cases (архитектурные)"
    },
    "domainModel": {
      "type": "object",
      "properties": {
        "entities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "properties": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "description": "Domain model (минимум)"
    },
    "dataSources": {
      "type": "object",
      "properties": {
        "repositories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dataSources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "description": "Источники данных"
    },
    "cachePolicy": {
      "type": "object",
      "properties": {
        "ttl": {
          "type": "string"
        },
        "swr": {
          "type": "string"
        },
        "refresh": {
          "type": "string"
        },
        "invalidation": {
          "type": "string"
        }
      },
      "description": "Политика кеша и обновления"
    },
    "degradationPolicy": {
      "type": "object",
      "properties": {
        "hide": {
          "type": "string"
        },
        "showAsPlaceholder": {
          "type": "string"
        },
        "globalError": {
          "type": "string"
        }
      },
      "description": "Политика деградации"
    },
    "analytics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "params": {
            "type": "object"
          },
          "whenFired": {
            "type": "string"
          }
        }
      },
      "description": "События аналитики"
    },
    "testRequirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["given", "when", "then"],
        "properties": {
          "given": {
            "type": "string"
          },
          "when": {
            "type": "string"
          },
          "then": {
            "type": "string"
          }
        }
      },
      "description": "Тестовые требования (Given/When/Then)"
    }
  }
}

